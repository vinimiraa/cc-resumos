			"index": "a3l",
			"roundness": null,
			"seed": 1243010711,
			"version": 731,
			"versionNonce": 407974423,
			"isDeleted": false,
			"boundElements": [],
			"updated": 1765212657804,
			"link": null,
			"locked": false,
			"text": "No Pipeline Escalar:\n- Com 1 thread: A é executado, mas pode gerar bolhas\n- Com 4 threads (IMT): Há uma execução intercalada das instruções \n                                das threads A, B, C e D.\n- Com 4 threads (BMT): Há uma execução intercalada dos blocos de \n                                instruções, executa 3 instruções do \n                                Bloco A, depois tem uma bolha e por fim\n                                executa 2 instruções do Bloco B.",
			"rawText": "No Pipeline Escalar:\n- Com 1 thread: A é executado, mas pode gerar bolhas\n- Com 4 threads (IMT): Há uma execução intercalada das instruções \n                                das threads A, B, C e D.\n- Com 4 threads (BMT): Há uma execução intercalada dos blocos de \n                                instruções, executa 3 instruções do \n                                Bloco A, depois tem uma bolha e por fim\n                                executa 2 instruções do Bloco B.",
			"fontSize": 20,
			"fontFamily": 5,
			"textAlign": "left",
			"verticalAlign": "top",
			"containerId": null,
			"originalText": "No Pipeline Escalar:\n- Com 1 thread: A é executado, mas pode gerar bolhas\n- Com 4 threads (IMT): Há uma execução intercalada das instruções \n                                das threads A, B, C e D.\n- Com 4 threads (BMT): Há uma execução intercalada dos blocos de \n                                instruções, executa 3 instruções do \n                                Bloco A, depois tem uma bolha e por fim\n                                executa 2 instruções do Bloco B.",
			"autoResize": true,
			"lineHeight": 1.25
		},
		{
			"id": "BiUqY9YX02b3hdQiE_peL",
