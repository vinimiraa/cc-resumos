		{
			"id": "IiL3DynQ",
			"type": "text",
			"x": 13.028863455949988,
			"y": 769.344139871221,
			"width": 658.03955078125,
			"height": 100,
			"angle": 0,
			"strokeColor": "#e03131",
			"backgroundColor": "transparent",
			"fillStyle": "solid",
			"strokeWidth": 1,
			"strokeStyle": "solid",
			"roughness": 1,
			"opacity": 100,
			"groupIds": [],
